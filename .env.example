# ShadowGate hosting environment example

# Required for hosted/public usage
SHADOWGATE_HOST=0.0.0.0
PORT=8000

# Recommended for production persistence
SHADOWGATE_DATA_DIR=/data

# Admin operations
SHADOWGATE_ADMIN_KEY=change-me-admin-key

# Normal scan/gateway usage
SHADOWGATE_CLIENT_KEY=change-me-client-key

# Audit retention configuration
SHADOWGATE_AUDIT_MAX_EVENTS=10000
SHADOWGATE_AUDIT_RETENTION_DAYS=30

# Rate-limit configuration hooks
SHADOWGATE_RATE_LIMIT_PER_MINUTE=120
SHADOWGATE_RATE_LIMIT_BURST=20
